# Groq API (LLaMA 3.3 Versatile)
GROQ_API_KEY=your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Pollinations.ai (FLUX image generation — free, no API key required)
# POLLINATIONS_MODEL=flux   # options: flux, flux-realism, flux-anime, flux-3d, turbo

# Deepgram TTS (Aura model)
DEEPGRAM_API_KEY=your-key-here
DEEPGRAM_TTS_MODEL=aura-asteria-en

# Output directories
OUTPUT_DIR=data/outputs
TEMP_DIR=data/temp
STATE_DIR=data/state_versions
SQLITE_DB_PATH=data/animora.db

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
