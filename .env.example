# Groq API (LLaMA 3.3 Versatile)
GROQ_API_KEY=your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudflare Workers AI (Stable Diffusion XL image generation)
CF_API_TOKEN=your-cloudflare-api-token-here
CF_ACCOUNT_ID=your-cloudflare-account-id-here

# Deepgram TTS (Aura model)
DEEPGRAM_API_KEY=your-key-here
DEEPGRAM_TTS_MODEL=aura-asteria-en

# Output directories
OUTPUT_DIR=data/outputs
TEMP_DIR=data/temp
STATE_DIR=data/state_versions
SQLITE_DB_PATH=data/animora.db

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
